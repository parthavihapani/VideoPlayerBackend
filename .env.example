# VideoPlayer Backend — Environment Configuration
# Copy this to .env and adjust as needed

# Directory where downloaded files are temporarily stored
DOWNLOAD_DIR=/tmp/videodl

# How long (seconds) before completed files are auto-deleted (default: 1 hour)
MAX_FILE_AGE_SECONDS=3600

# Max simultaneous download jobs (default: 3)
MAX_CONCURRENT=3

# Optional API key for authentication (leave blank to disable auth)
# If set, Android app must send header: X-API-Key: your_key_here
API_KEY=

# Optional proxy URL for yt-dlp (useful for geo-restricted content)
# Examples:
#   PROXY_URL=socks5://user:pass@127.0.0.1:1080
#   PROXY_URL=http://proxy.example.com:8080
PROXY_URL=

# Max number of playlist entries to return (default: 10)
MAX_PLAYLIST=10

# Rate limit per IP per minute (0 = disabled, default: 30)
RATE_LIMIT_PER_MIN=30
